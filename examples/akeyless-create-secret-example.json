{
  "title": "Create a Static Secret",
  "description": "Create a new static secret in the Akeyless vault via POST /create-secret.",
  "request": {
    "method": "POST",
    "url": "https://api.akeyless.io/create-secret",
    "headers": {
      "Content-Type": "application/json",
      "Accept": "application/json"
    },
    "body": {
      "name": "/prod/database/password",
      "value": "s3cr3tP@ssw0rd",
      "description": "Production database password for PostgreSQL",
      "tags": ["env:prod", "team:platform", "service:database"],
      "token": "t-1234567890abcdef1234567890abcdef"
    }
  },
  "response": {
    "status": 200,
    "body": {
      "item_id": 123456789,
      "item_name": "/prod/database/password"
    }
  }
}
